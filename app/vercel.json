{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/checklist-lookup.ts": {
      "includeFiles": "api/_lib/checklists/**",
      "maxDuration": 60
    },
    "api/vision-capture.ts": {
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    },
    "api/scan-batch-create.ts": {
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    },
    "api/scan-batch-page.ts": {
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs"
    }
  }
}
